# RAG出題に必須。Anthropic の API キー。
# 未設定の場合、固定プール方式は動作するが RAG 出題は 503 を返す。
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxx

# 任意設定（既定値は config.py 参照）
RAG_MODEL=claude-haiku-4-5-20251001
RAG_CHOICES=3
RAG_QUESTIONS_PER_QUIZ=10
RAG_SESSION_TTL_SEC=7200
RAG_VERIFY_PASS=false

# 管理画面トークン（URL難読化）。フロントの admin-<token>.html と一致させる。
ADMIN_TOKEN=Kp7vQm2xRt

# 履歴・RAGセッションDBのパス（任意。既定は backend/quiz.db）
# DATABASE_PATH=/var/data/quiz.db
